# Clerk Auto-Refresh Auth (recommended — log in once, never touch again)
# 1. Open Chrome → app.skylit.ai (make sure you're logged in)
# 2. DevTools → Network tab → filter "tokens"
# 3. Find a POST to clerk.skylit.ai/v1/client/sessions/sess_.../tokens
# 4. Session ID = the sess_... from the URL path
# 5. __client cookie = from the Cookie header (the eyJ... value after __client=)
# 6. __client_uat = from the Cookie header (the number after __client_uat=)
CLERK_SESSION_ID=sess_xxxxx
CLERK_CLIENT_COOKIE=eyJhbGci...
CLERK_CLIENT_UAT=1234567890

# Heatseeker Auth (static fallback — only if Clerk isn't working)
HEATSEEKER_JWT=
HEATSEEKER_COOKIES=

# Discord (from Server Settings → Webhooks)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your/webhook

# Kimi / Moonshot AI Agent
KIMI_API_KEY=sk-your-moonshot-api-key
AGENT_MODEL=moonshot-v1-auto
AGENT_TEMPERATURE=0.1
AGENT_MAX_TOKENS=500

# Claude Sonnet (nightly/weekly review agent)
ANTHROPIC_API_KEY=sk-ant-your-key-here
SONNET_MODEL=claude-sonnet-4-20250514
SONNET_MAX_TOKENS=4096

# Polygon.io (free tier — 15-min delayed quotes)
POLYGON_API_KEY=your-polygon-api-key

# Dashboard
DASHBOARD_PORT=3002

# TradingView Webhook Server
TV_WEBHOOK_PORT=3001
TV_WEBHOOK_SECRET=your-random-secret-here

# System
NODE_ENV=development
LOG_LEVEL=debug
DATA_DIR=./data
CYCLE_INTERVAL_MS=30000

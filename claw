#!/bin/bash
# OpenClaw CLI — Quick commands for managing the SPX bot
# Usage: ./claw <command>

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR"

case "$1" in
  status)
    pm2 status
    ;;
  start)
    pm2 start ecosystem.config.cjs
    ;;
  stop)
    pm2 stop openclaw
    ;;
  restart)
    pm2 restart openclaw
    ;;
  logs)
    pm2 logs ${2:-openclaw} --lines 50
    ;;
  gex)
    node -e "
      import('./src/utils/config.js');
      import('./src/store/db.js').then(db => {
        const data = db.getLatestGex();
        console.log(JSON.stringify(data, null, 2));
      });
    "
    ;;
  health)
    node -e "
      import('./src/utils/config.js');
      import('./src/store/db.js').then(db => {
        const data = db.getHealth();
        console.log(JSON.stringify(data, null, 2));
      });
    "
    ;;
  test-alert)
    node -e "
      import('./src/utils/config.js');
      import('./src/alerts/discord.js').then(d => d.sendTest());
    "
    ;;
  run)
    node src/index.js
    ;;
  launch)
    echo "=== OpenClaw Launch ==="
    echo ""

    # 1. Build dashboard
    echo "[1/4] Building dashboard..."
    cd dashboard && npm run build > /dev/null 2>&1 && cd ..
    echo "  Dashboard built."

    # 2. Start backend + dashboard via PM2
    echo "[2/4] Starting services via PM2..."
    pm2 start ecosystem.config.cjs --silent
    sleep 2
    echo "  Backend:   http://localhost:3002"
    echo "  Dashboard: http://localhost:3000"

    # 3. Start ngrok tunnel for TV webhooks
    echo "[3/4] Starting ngrok tunnel (port 3001)..."
    ngrok http 3001 --log=stdout --log-level=warn > /tmp/openclaw-ngrok.log 2>&1 &
    NGROK_PID=$!
    echo $NGROK_PID > /tmp/openclaw-ngrok.pid
    sleep 3

    # Get tunnel URL from ngrok API
    TUNNEL_URL=$(curl -s http://127.0.0.1:4040/api/tunnels 2>/dev/null | node -e "
      let d=''; process.stdin.on('data',c=>d+=c); process.stdin.on('end',()=>{
        try { const t=JSON.parse(d).tunnels.find(t=>t.proto==='https');
          console.log(t?t.public_url:'FAILED');
        } catch { console.log('FAILED'); }
      });
    " 2>/dev/null)

    if [ "$TUNNEL_URL" = "FAILED" ] || [ -z "$TUNNEL_URL" ]; then
      echo "  ngrok failed to start. Check: ngrok config check"
      echo "  TV webhooks won't work without a tunnel."
    else
      echo "  Tunnel:    $TUNNEL_URL"
      echo ""
      echo "  TradingView webhook URL:"
      echo "  $TUNNEL_URL/webhook/tv?token=YOUR_SECRET"
    fi

    # 4. Open dashboard
    echo ""
    echo "[4/4] Opening dashboard..."
    open http://localhost:3000 2>/dev/null || true

    echo ""
    echo "=== OpenClaw is live ==="
    echo "  ./claw logs       — view logs"
    echo "  ./claw status     — PM2 status"
    echo "  ./claw shutdown   — stop everything"
    ;;
  shutdown)
    echo "Shutting down OpenClaw..."
    pm2 stop ecosystem.config.cjs --silent 2>/dev/null
    pm2 delete ecosystem.config.cjs --silent 2>/dev/null
    if [ -f /tmp/openclaw-ngrok.pid ]; then
      kill "$(cat /tmp/openclaw-ngrok.pid)" 2>/dev/null
      rm -f /tmp/openclaw-ngrok.pid
    fi
    echo "All services stopped."
    ;;
  strategy)
    node -e "
      import('./src/review/strategy-store.js').then(s => {
        s.initStrategyStore();
        const cfg = s.getActiveConfig();
        const ver = s.getActiveVersionNumber();
        const history = s.getVersionHistory();
        console.log('Active Strategy: v' + ver);
        console.log('Config keys:', Object.keys(cfg).length);
        console.log('');
        console.log('Key parameters:');
        console.log('  gex_min_score:', cfg.gex_min_score);
        console.log('  gex_strong_threshold:', cfg.gex_strong_threshold || cfg.gex_strong_score);
        console.log('  no_entry_after:', cfg.no_entry_after);
        console.log('  tv_weight_bravo:', cfg.tv_weight_bravo, '/ tv_weight_tango:', cfg.tv_weight_tango);
        console.log('');
        console.log('Version history (' + history.length + ' total):');
        history.slice(0, 5).forEach(v => {
          const changes = JSON.parse(v.change_summary || '[]');
          const active = v.is_active ? ' [ACTIVE]' : '';
          console.log('  v' + v.version + ' (' + v.source + ') - ' + changes.length + ' changes' + active);
        });
      });
    "
    ;;
  review)
    echo "Running manual nightly review..."
    node -e "
      import('./src/review/strategy-store.js').then(s => {
        s.initStrategyStore();
        import('./src/review/nightly-review.js').then(async (r) => {
          const result = await r.runNightlyReview();
          console.log(JSON.stringify(result, null, 2));
        });
      });
    "
    ;;
  briefing)
    node -e "
      import('./src/store/db.js').then(db => {
        const briefing = db.getLatestBriefing();
        if (!briefing) {
          console.log('No briefing found. Run a nightly review first.');
          return;
        }
        console.log('Date:', briefing.date);
        console.log('Version:', briefing.version);
        console.log('');
        console.log(briefing.briefing);
        const changes = JSON.parse(briefing.changes || '[]');
        if (changes.length > 0) {
          console.log('');
          console.log('Changes:');
          changes.forEach(c => console.log('  ' + c.param + ':', c.old, '->', c.new));
        }
        const perf = JSON.parse(briefing.performance_summary || '{}');
        if (perf.trades) {
          console.log('');
          console.log('Yesterday: ' + perf.trades + ' trades, ' + perf.wins + 'W/' + perf.losses + 'L, $' + perf.totalPnlDollars);
        }
      });
    "
    ;;
  *)
    echo "OpenClaw SPX Trading System"
    echo ""
    echo "Usage: ./claw <command>"
    echo ""
    echo "Commands:"
    echo "  launch      Start everything (backend + dashboard + ngrok)"
    echo "  shutdown    Stop everything"
    echo "  status      Show PM2 process status"
    echo "  start       Start the bot via PM2"
    echo "  stop        Stop the bot"
    echo "  restart     Restart the bot"
    echo "  logs [n]    Show recent logs"
    echo "  gex         Show latest GEX snapshot"
    echo "  health      Show health status"
    echo "  test-alert  Send a test Discord message"
    echo "  run         Run directly (no PM2)"
    echo "  strategy    Show active strategy version + config"
    echo "  review      Run a manual nightly review"
    echo "  briefing    Show latest morning briefing"
    ;;
esac
